{
  "name": "suttacentral-api",
  "version": "2.26.17",
  "description": "SuttaCentral API cached proxy",
  "main": "index.js",
  "directories": {
    "test": "test"
  },
  "dependencies": {
    "log-instance": "^1.9.0",
    "memo-again": "^0.12.0",
    "merkle-json": "^2.15.0"
  },
  "devDependencies": {
    "@sc-voice/vitest": "^4.0.0"
  },
  "scripts": {
    "build": "scripts/build",
    "test": "vitest run",
    "test:test": "vitest"
  },
  "repository": {
    "tag": "git"
  },
  "bin": {},
  "keywords": [
    "SuttaCentral",
    "translation",
    "Javascript",
    "Voice"
  ],
  "author": "Karl Lew",
  "homepage": "https://github.com/sc-voice/sc-api",
  "license": "MIT",
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/essential",
      "eslint:recommended"
    ],
    "rules": {
      "no-console": "off"
    },
    "parserOptions": {
      "parser": "babel-eslint"
    }
  },
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 8"
  ]
}
